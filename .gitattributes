# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.md text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
